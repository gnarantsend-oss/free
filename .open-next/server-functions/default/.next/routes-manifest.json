{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/foreign/watch/[id]",
      "regex": "^/foreign/watch/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/foreign/watch/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/media/movie/[id-slug]",
      "regex": "^/media/movie/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPidslug": "nxtPid-slug"
      },
      "namedRegex": "^/media/movie/(?<nxtPidslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/media/tv/[id-slug]",
      "regex": "^/media/tv/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPidslug": "nxtPid-slug"
      },
      "namedRegex": "^/media/tv/(?<nxtPidslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/media/[type]/[id-slug]",
      "regex": "^/media/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtype": "nxtPtype",
        "nxtPidslug": "nxtPid-slug"
      },
      "namedRegex": "^/media/(?<nxtPtype>[^/]+?)/(?<nxtPidslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/mongol/watch/[id]",
      "regex": "^/mongol/watch/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/mongol/watch/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/view/movie/[id-slug]",
      "regex": "^/view/movie/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPidslug": "nxtPid-slug"
      },
      "namedRegex": "^/view/movie/(?<nxtPidslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/view/tv/[id-slug]",
      "regex": "^/view/tv/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPidslug": "nxtPid-slug"
      },
      "namedRegex": "^/view/tv/(?<nxtPidslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/view/[type]/[id-slug]",
      "regex": "^/view/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtype": "nxtPtype",
        "nxtPidslug": "nxtPid-slug"
      },
      "namedRegex": "^/view/(?<nxtPtype>[^/]+?)/(?<nxtPidslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/disclaimer",
      "regex": "^/disclaimer(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/disclaimer(?:/)?$"
    },
    {
      "page": "/dmca",
      "regex": "^/dmca(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dmca(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/foreign",
      "regex": "^/foreign(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/foreign(?:/)?$"
    },
    {
      "page": "/mongol",
      "regex": "^/mongol(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mongol(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}